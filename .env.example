# Database (Neon Postgres in prod, local Postgres in dev)
DATABASE_URL=postgresql://user:password@localhost:5432/ansem_dev

# Clerk auth — publishable placeholder is parse-valid (base64 of clerk.example.com$)
# and deliberately LIVE-shaped: dev-instance (pk_test_) keys make clerkMiddleware
# 307 every browser document request to the FAPI dev-browser handshake
# (clerk.example.com — unresolvable), breaking every page offline. Production-shaped
# keys resolve signed-out visitors locally with zero Clerk calls.
# Swap in real pk_test_/sk_test_ values to actually sign in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuZXhhbXBsZS5jb20k
CLERK_SECRET_KEY=sk_live_placeholder
# Local catch-all auth routes — auth.protect() redirects signed-out visitors here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Cron route bearer secret
CRON_SECRET=replace-with-long-random-string

# Metrics providers (spec 003) — mock | live; mock is the dev fallback and is
# never served in production (unconfigured platforms are skipped there)
METRICS_PROVIDER=mock
# Optional per-platform overrides (mock | live) — beat METRICS_PROVIDER
METRICS_PROVIDER_X=
METRICS_PROVIDER_TIKTOK=
METRICS_PROVIDER_INSTAGRAM=
X_BEARER_TOKEN=
SOCIALDATA_API_KEY=
APIFY_TOKEN=

# X discovery cron (spec 005) — the whole feature is OFF unless this is "true"
# AND X_BEARER_TOKEN is set. ⚠️ Set the X console spend cap BEFORE enabling:
# search reads are pay-per-use ($5/1k); the page budget below is the per-run bound.
X_DISCOVERY_ENABLED=false
# Recent-search query override; default (with the documented cashtag fallback)
# lives in src/server/discovery/discover-x.ts. If X rejects the $ANSEM cashtag
# operator, set this to the quoted-keyword fallback documented there.
X_SEARCH_QUERY=
# Max search pages (100 results each) per run; default 3
X_DISCOVERY_PAGES_PER_RUN=

# Ingestion cron (spec 004) — posts refreshed per run, stalest first; default 200
REFRESH_BATCH_SIZE=
# Per-run provider sub-batch budget (≤ 100 posts per call); default 10 — a
# misconfigured batch size can never fan out unbounded provider calls
MAX_PROVIDER_CALLS_PER_RUN=

# Admin moderation (spec 009) — comma-separated Clerk user ids; empty = no admins
ADMIN_USER_IDS=

# Submissions (spec 002) — "true" skips the moderation queue; default false
AUTO_APPROVE_SUBMISSIONS=false
